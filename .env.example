# App
APP_ENV=local
APP_NAME=fastapi-auth
APP_LOG_LEVEL=INFO

# HTTP
APP_HOST=0.0.0.0
APP_PORT=8000
APP_CORS_ORIGINS=
APP_TRUSTED_HOSTS=
APP_TRUST_PROXY=false

# Database
DATABASE_URL=postgresql+psycopg://auth:auth@localhost:5432/auth

# JWT (no real secrets here)
JWT_ALG=EdDSA
JWT_PRIVATE_KEY=
JWT_PRIVATE_KEY_KID=
# JSON object: {"kid1":"-----BEGIN PUBLIC KEY-----..."}
JWT_PUBLIC_KEYS=
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30
REFRESH_TOKEN_PEPPER=
PASSWORD_RESET_TOKEN_TTL_MINUTES=30
PASSWORD_RESET_TOKEN_PEPPER=

# Logging (sensitive metadata off by default)
LOG_INCLUDE_IP=false
LOG_INCLUDE_USER_AGENT=false
LOG_INCLUDE_EMAIL=false

# Rate limiting
RATE_LIMIT_ENABLED=false
RATE_LIMIT_PROVIDER=
